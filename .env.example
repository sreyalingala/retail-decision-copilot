# Frontend (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend (FastAPI)
PORT=8000
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OpenAI (Responses API)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4.1-mini

# Postgres / Neon
# Local Postgres example (SQLAlchemy psycopg driver)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/retail_decision_copilot
# Neon example (sslmode=require)
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Optional read-only connection string if you configure one
DATABASE_READONLY_URL=postgresql+psycopg://readonly_user:readonly_password@localhost:5432/retail_decision_copilot

# SQL Guardrails
SQL_MAX_ROWS=200
SQL_STATEMENT_TIMEOUT_MS=5000

