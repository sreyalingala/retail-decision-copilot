# Frontend (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend (FastAPI)
PORT=8000
CORS_ORIGINS=http://localhost:3000

# OpenAI (Responses API)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4.1-mini

# Postgres / Neon
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/retail_decision_copilot
DATABASE_READONLY_URL=postgresql://readonly_user:readonly_password@localhost:5432/retail_decision_copilot

# SQL Guardrails
SQL_MAX_ROWS=200
SQL_STATEMENT_TIMEOUT_MS=5000

